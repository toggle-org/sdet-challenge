  "description": "NestJS Backend with CQRS for SDET Challenge",
  "author": "SDET Challenge",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
